Meta.DisplayName=SBox Dedicated Server Meta.Description=s&box Dedicated Server template for AMP Meta.OS=Windows, Linux Meta.AarchSupport=NotSupported Meta.Arch=x86_64 Meta.Author=TeamKit / hydrocut Meta.URL=https://sbox.game/dev/doc/networking/dedicated-servers/ Meta.DisplayImageSource=steam:590830 Meta.EndpointURIFormat=steam://connect/{ip}:{GenericModule.App.Ports.$ServerPort} Meta.ConfigManifest=sboxconfig.json Meta.MetaConfigManifest=sboxmetaconfig.json Meta.ConfigRoot=sbox.kvp Meta.MinAMPVersion=2.5.0.0 Meta.SpecificDockerImage=cubecoders/ampbase:debian Meta.DockerRequired=False Meta.DockerBaseReadOnly=False Meta.ContainerPolicy=Supported Meta.ContainerPolicyReason=Linux requires the .NET Runtime to be installed. Meta.ExtraSetupStepsURI=https://sbox.game/dev/doc/networking/dedicated-servers/ Meta.Prerequisites=[] Meta.ExtraContainerPackages=[] Meta.ConfigReleaseState=NotSpecified Meta.NoCommercialUsage=False Meta.ConfigVersion=2 Meta.ReleaseNotes=Rename display name to SBox and add metaconfig manifest. Meta.BreakingReleaseNotes= Meta.AppConfigId=bdc6e2bb-df41-4d73-8f94-736292939742 Meta.ImportableExtensions=[] Meta.AppIsMultiIPAware=True App.DisplayName=SBox Dedicated Server App.RootDir=./sbox/ App.BaseDirectory=./sbox/1892930/ App.SteamWorkshopDownloadLocation= App.ExecutableWin=1892930\sbox-server.exe App.ExecutableLinux=1892930/sbox-server.exe App.WorkingDir=1892930 App.LinuxCommandLineArgs= App.WindowsCommandLineArgs= App.CommandLineArgs={{$PlatformArgs}} +game "{{GamePackage}}" "{{MapPackage}}" +hostname "{{ServerName}}" +port {{$ServerPort}} +net_query_port {{$QueryPort}} {{$FormattedArgs}} {{CustomServerArgs}} App.UseLinuxIOREDIR=False App.AppSettings={} App.EnvironmentVariables={"SteamAppId":"590830"} App.CommandLineParameterFormat=+{0} "{1}" App.CommandLineParameterDelimiter= App.ExitMethod=OS_CLOSE App.ExitTimeout=30 App.ExitString= App.ExitFile=app_exit.lck App.HasWriteableConsole=True App.HasReadableConsole=True App.UDPLogger=False App.SupportsLiveSettingsChanges=False App.LiveSettingChangeCommandFormat={0} "{1}" App.ForceIPBinding=False App.SupportsIPv6=False App.ApplicationIPBinding=0.0.0.0 App.Ports=@IncludeJson[sboxports.json] App.AdminPortRef=0 App.PrimaryApplicationPortRef=ServerPort App.UniversalSleepApplicationUDPPortRef=ServerPort App.UniversalSleepSteamQueryPortRef=QueryPort App.MaxUsers=16 App.UseRandomAdminPassword=False App.PersistRandomPassword=False App.RemoteAdminPassword= App.AdminMethod=STDIO App.IgnoreSTDOUTAfterRCON=False App.AdminLoginTransform=None App.LoginTransformPrefix= App.RCONConnectDelaySeconds=5 App.RCONConnectRetrySeconds=5 App.RCONHeartbeatMinutes=0 App.RCONHeartbeatCommand=ping App.TelnetLoginFormat={0} App.UpdateSources=@IncludeJson[sboxupdates.json] App.PreStartStages=[] App.UserActions=[] App.ForceUpdate=False App.ForceUpdateReason= App.Compatibility=None App.SteamUpdateAnonymousLogin=True App.SteamForceLoginPrompt=False App.RapidStartup=False App.SmartExcludeExemptions=["*.cfg","*.conf","*.config","*.ini","*.json","*.xml","*.properties","*.kvp","*.yml","*.yaml","*.toml","*.lua"] App.SmartExcludeSupported=True App.MonitorChildProcess=False App.DumpFullChildProcessTree=False App.MonitorChildProcessWaitMs=100 App.MonitorChildProcessName= App.MonitorDirectChildOnly=False App.SupportsUniversalSleep=False App.WakeupMode=Any App.ApplicationReadyMode=Immediate App.TemplateMatchRegex={{(!?(?Linux|Windows|All):)?(?\$?[\w]+)}} Console.FilterMatchRegex= Console.FilterMatchReplacement= Console.ThrowawayMessageRegex=^(WARNING|ERROR): Shader.+$ Console.AppReadyRegex=^.*$ Console.UserJoinRegex=^$ Console.UserLeaveRegex=^$ Console.UserChatRegex=^$ Console.UpdateAvailableRegex=^$ Console.MetricsRegex= Console.SuppressLogAtStart=False Console.ActivateLogRegex= Console.PreConnectRegex= Console.ConnectIPRegex= Console.UserActions={} Limits.SleepMode=False Limits.SleepOnStart=False Limits.SleepDelayMinutes=5 Limits.DozeDelay=2 Limits.AutoRetryCount=2 Limits.SleepStartThresholdSeconds=25
